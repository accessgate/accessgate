{
  "upstream_url": "http://localhost:3000",
  "proxy_path_prefix": "/graphql",
  "require_auth": true,
  "auth_url": "http://localhost:8080",
  "cookie_name": "__Host-ess_session",
  "http_port": "8081",

  "policy_engine": "wasm",
  "policy_bundle_path": "",
  "policy_fallback_allow": true,

  "pipeline_plugins": [
    {
      "id": "pipeline:ratelimit",
      "type": "ratelimit",
      "raw": {
        "name": "default",
        "requests_per_minute": 60,
        "burst": 10,
        "key_strategy": "ip"
      }
    }
  ],

  "headers_user_id_claim": "sub",
  "headers_email_claim": "email",
  "headers_name_claim": "name",
  "headers_preferred_username_claim": "preferred_username",
  "headers_roles_claim": "realm_access.roles",
  "headers_groups_claim": "groups",
  "headers_tenant_id_claim": "",
  "headers_admin_role": "admin"
}

