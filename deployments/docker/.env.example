# AccessGate quickstart — local environment.
#
#   cp .env.example .env
#   docker compose up
#
# These are LOCAL-ONLY development defaults. Never reuse them in any shared,
# staging, or production environment. The only value you MUST set is
# COOKIE_SIGNING_SECRET (compose refuses to start without it).

# --- Required ---------------------------------------------------------------

# Secret used to sign the session cookie (accessgate-auth). Any non-empty value
# works for local dev. Generate a strong one with:
#   openssl rand -hex 32
# The literal "CHANGE-ME-in-production" is rejected by config validation.
COOKIE_SIGNING_SECRET=local-dev-cookie-signing-secret-change-me

# --- OIDC client (mock IdP) -------------------------------------------------

# Client id/secret accessgate-auth presents to the mock IdP. The mock does not
# validate them, so any non-empty values are fine locally. The literal
# "your-client-secret" is rejected by config validation.
OIDC_CLIENT_ID=accessgate-local
OIDC_CLIENT_SECRET=local-mock-secret

# Identity the mock IdP issues for an interactive login (optional).
MOCKIDP_SUB=quickstart-user
MOCKIDP_EMAIL=quickstart-user@example.com

# --- Admin / demo controls --------------------------------------------------

# Guards the /admin and /internal/session endpoints on accessgate-auth. Empty
# disables those endpoints. Not needed for the default policy-only curl demo.
ADMIN_SECRET=local-admin-secret

# When "false" (default) the sample policy alone decides allow vs deny, so the
# curl demo needs no login. Set to "true" to ALSO require an authenticated
# session — unauthenticated requests then get 401 (see README).
REQUIRE_AUTH=false
